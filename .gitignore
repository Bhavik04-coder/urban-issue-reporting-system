# ===========================
# UrbanSim AI — Root .gitignore
# ===========================

# ---------- Python ----------
.venv/
venv/
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# ---------- Node / npm ----------
node_modules/
npm-debug.*
yarn-debug.*
yarn-error.*

# ---------- Expo / React Native ----------
.expo/
web-build/
*.tsbuildinfo
.metro-health-check*

# Native build output
frontend/**/ios/
frontend/**/android/
frontend/**/.kotlin/

# ---------- ML Artifacts ----------
# Large model files (should be downloaded or trained locally)
# *.h5
# *.pkl

# ---------- Databases ----------
*.sqlite3
*.db

# ---------- Environment / Secrets ----------
.env
.env*.local

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Flutter ----------
civic_eye_app/build/
civic_eye_app/.dart_tool/
civic_eye_app/.flutter-plugins
civic_eye_app/.flutter-plugins-dependencies
civic_eye_app/pubspec.lock
civic_eye_app/android/.gradle/
civic_eye_app/android/local.properties
civic_eye_app/android/app/debug.keystore
civic_eye_app/ios/Pods/
civic_eye_app/ios/.symlinks/
civic_eye_app/ios/Flutter/Generated.xcconfig
civic_eye_app/ios/Flutter/flutter_export_environment.sh
civic_eye_app/web/sqlite3.wasm
civic_eye_app/web/sqflite_sw.js

# ---------- Logs ----------
*.log

# ---------- Keys & Certs ----------
*.jks
*.p8
*.p12
*.key
*.pem
*.mobileprovision
*.orig.*
