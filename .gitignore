# ===========================
# UrbanSim AI — Root .gitignore
# ===========================

# ---------- Python ----------
.venv/
venv/
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# ---------- Node / npm ----------
node_modules/
npm-debug.*
yarn-debug.*
yarn-error.*

# ---------- Expo / React Native ----------
.expo/
web-build/
*.tsbuildinfo
.metro-health-check*

# Native build output
frontend/**/ios/
frontend/**/android/
frontend/**/.kotlin/

# ---------- ML Artifacts ----------
# Large model files (should be downloaded or trained locally)
# *.h5
# *.pkl

# ---------- Databases ----------
*.sqlite3
*.db

# ---------- Environment / Secrets ----------
.env
.env*.local

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Logs ----------
*.log

# ---------- Keys & Certs ----------
*.jks
*.p8
*.p12
*.key
*.pem
*.mobileprovision
*.orig.*
